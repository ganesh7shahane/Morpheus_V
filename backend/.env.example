# Copy this file to .env and fill in the values if the defaults don't work.
# The backend will also read these from your shell environment.

# ── Retrosynthetic Planning (optional feature) ────────────────────────────────

# Full path to the Python executable inside the 'synplanner' conda environment.
# The backend auto-detects common install locations; only set this if detection fails.
# SYNPLANNER_PYTHON=/Users/yourname/miniconda3/envs/synplanner/bin/python

# Directory containing the SynPlanner model weights (reaction rules + policy networks).
# These ~2 GB files are NOT included in the repo — see README for download instructions.
# Default: <repo_root>/synplan_data
# SYNPLAN_DATA_DIR=/path/to/synplan_data

# Path to the building-blocks SDF.gz used by the retrosynthesis planner.
# Default: <repo_root>/data/building_blocks_em_sa_ln_with_ids.sdf.gz
# BB_SDF_GZ=/path/to/building_blocks_em_sa_ln_with_ids.sdf.gz
